{
  "name": "tarralappu",
  "version": "1.9.2",
  "private": true,
  "type": "module",
  "description": "Sticky-note harness for AI image generation via OpenRouter",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsgo-experimental-api --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsgo-experimental-api --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "idb": "^8.0.3",
    "svelte": "^5.56.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  }
}
